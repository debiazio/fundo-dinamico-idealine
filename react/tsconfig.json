{
  "extends": "@vtex/tsconfig",
  "compilerOptions": {
    "noEmitOnError": false,
    "lib": [
      "dom",
      "es2017",
      "es2016.array.include"
    ],
    "module": "esnext",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "target": "es2016"
  },
  "include": [
    "./typings/*.d.ts",
    "./**/*.tsx",
    "./**/*.ts",
    "./**/*.js",
    "./**/*.jsx"
  ]
}
